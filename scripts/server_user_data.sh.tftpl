#!/bin/bash
apt-get update
apt-get install -y docker.io docker-compose git
systemctl start docker
systemctl enable docker

mkdir -p /opt/kanshi
cd /opt/kanshi

# Clone the demo repo
git clone https://github.com/kanshi-dev/demo.git .

# Use the provided .env or example
cat <<EOT > .env
${env_file_content}
EOT

docker-compose up -d
