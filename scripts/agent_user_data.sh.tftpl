#!/bin/bash
apt-get update
apt-get install -y wget tar netcat-openbsd

mkdir -p /opt/kanshi-agent
cd /opt/kanshi-agent

wget https://github.com/kanshi-dev/agent/releases/download/v0.1.0/agent_0.1.0_linux_arm64.tar.gz
tar -xzf agent_0.1.0_linux_arm64.tar.gz

# Create a systemd unit for the Kanshi Agent
cat <<EOT > /etc/systemd/system/kanshi-agent.service
[Unit]
Description=Kanshi Agent
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/kanshi-agent
Environment=KANSHI_CORE_ADDR=${kanshi_server_private_ip}:50051
ExecStartPre=/usr/bin/bash -c 'until nc -z ${kanshi_server_private_ip} 80; do echo "Waiting for server..."; sleep 5; done'
ExecStart=/opt/kanshi-agent/kanshi-agent
Restart=always
RestartSec=5
StandardOutput=append:/opt/kanshi-agent/agent.log
StandardError=append:/opt/kanshi-agent/agent.log

[Install]
WantedBy=multi-user.target
EOT

systemctl daemon-reload
systemctl enable kanshi-agent
systemctl start kanshi-agent
